{
  "name": "somno-landing",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Landing page Somno — sistema de massagem para colchoes e poltronas (Rainoah).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && vite build --ssr src/entry-server.tsx --outDir dist/server && node scripts/prerender.mjs",
    "preview": "vite preview --port 4173",
    "optimize:img": "node scripts/optimize-images.mjs"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.6",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.61.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.0.6",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  }
}
